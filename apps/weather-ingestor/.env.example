# -------------------------------------------------------------------------
# weather-ingestor — environment variable reference
# Copy this file to .env (gitignored) for local development ONLY.
# In Azure, configure these as Container App / ACI environment variables,
# wired from Bicep outputs. NEVER commit .env with real values.
# -------------------------------------------------------------------------

# --- Azure managed identity path (used in Azure deployments) ---
# Cosmos DB account endpoint. Set by Bicep output: cosmosAccountEndpoint.
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/

# Optional: client ID of a user-assigned managed identity.
# Only needed when using a user-assigned identity; omit for system-assigned.
# AZURE_CLIENT_ID=<managed-identity-client-id>

# --- Local development path (connection string fallback) ---
# Only used when COSMOS_ENDPOINT is not set or for local Cosmos Emulator.
# NEVER commit with a real connection string.
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=C2y6...

# --- Cosmos DB target (defaults match Bicep-provisioned names) ---
# Database name. Bicep output: cosmosDatabaseName. Default: "demo"
COSMOS_DATABASE_NAME=demo

# Container name. Bicep output: cosmosContainerName. Default: "weather"
COSMOS_CONTAINER_NAME=weather

# --- Ingestion cadence ---
# Milliseconds between document writes. Default: 20000 (20 seconds).
INGEST_INTERVAL_MS=20000
