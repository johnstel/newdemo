# -------------------------------------------------------------------------
# backup-exporter — environment variable reference
# Copy this file to .env (gitignored) for local development ONLY.
# In Azure, configure these as Container App / ACI environment variables,
# wired from Bicep outputs. NEVER commit .env with real values.
# -------------------------------------------------------------------------

# --- Azure managed identity path (used in Azure deployments) ---
# Cosmos DB account endpoint. Set by Bicep output: cosmosAccountEndpoint.
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/

# Export Blob Storage account name. Set by Bicep output: exportStorageAccountName.
EXPORT_STORAGE_ACCOUNT_NAME=<your-export-storage-account>

# Optional: client ID of a user-assigned managed identity.
# Only needed when using a user-assigned identity; omit for system-assigned.
# AZURE_CLIENT_ID=<managed-identity-client-id>

# --- Local development path ---
# Only used when COSMOS_ENDPOINT / EXPORT_STORAGE_ACCOUNT_NAME are not set.
# Suitable for Cosmos Emulator and Azurite local storage emulator.
# NEVER commit with real connection strings.
# COSMOS_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=C2y6...
# STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;...

# --- Cosmos DB target (defaults match Bicep-provisioned names) ---
COSMOS_DATABASE_NAME=demo
COSMOS_CONTAINER_NAME=weather

# --- Export target ---
# Blob container for exports. Default: "cosmos-exports"
EXPORT_CONTAINER_NAME=cosmos-exports

# --- Export window ---
# Hours of data included in each export bundle. Default: 6
EXPORT_WINDOW_HOURS=6

# --- Run mode ---
# Leave unset (single-run mode): container job scheduler controls recurrence.
# Set to milliseconds (loop mode): exporter repeats in-process on this interval.
# Example for 6-hour in-process loop: EXPORT_LOOP_INTERVAL_MS=21600000
# EXPORT_LOOP_INTERVAL_MS=
